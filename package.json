{
  "name": "ide-platform",
  "version": "1.0.0",
  "description": "AI-powered IDE platform with autonomous agents",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "workers": "node server/workers/start.js",
    "build:docker": "docker build -t ide-workspace ./docker",
    "docker:run": "docker-compose up",
    "docker:stop": "docker-compose down",
    "setup:redis": "docker run -d -p 6379:6379 --name redis-ai redis:7-alpine"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "bullmq": "^4.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "node-fetch": "^3.3.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "ide",
    "ai",
    "agents",
    "gitpod",
    "code-server"
  ],
  "author": "CtxPod Team",
  "license": "MIT"
}
